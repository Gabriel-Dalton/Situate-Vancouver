# Repository root — loaded by Django via backend/config/settings.py (load_dotenv).
# This file is gitignored; do not commit real secrets.

# --- Django ---
DJANGO_SECRET_KEY=change-me-in-dev
DJANGO_DEBUG=true
# ".ageforty.com" allows apex, www, and any subdomain (see Django ALLOWED_HOSTS docs).
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,.ageforty.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://ageforty.com,https://www.ageforty.com
DJANGO_USE_X_FORWARDED_HEADERS=true
# Tunnel / odd Host headers: only honored while DJANGO_DEBUG=true (see settings.py).
DJANGO_ALLOW_ALL_HOSTS=true
DJANGO_RUNSERVER_PORT=1111

# --- CORS (comma-separated origins) ---
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://127.0.0.1:1111,http://localhost:1111

# --- AI service (FastAPI CORS when running uvicorn locally) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000,http://127.0.0.1:1111,http://localhost:1111

# --- Django → AI service ---
AI_SERVICE_URL=http://127.0.0.1:8001
# false = skip AI in GET /api/health when uvicorn is not running (errno 61 otherwise).
HEALTH_CHECK_AI=false

# --- Vancouver Open Data (Opendatasoft Explore API v2.1) ---
# Create a key at https://opendata.vancouver.ca/account/ — use Authorization: Apikey <key> (handled in code).
VANCOUVER_OPENDATA_BASE_URL=https://opendata.vancouver.ca
VANCOUVER_OPENDATA_API_KEY=21b7344baf33a9ec6e53f506fdc38da52d82a506011b53bb3caf8483
VANCOUVER_OPENDATA_TIMEOUT_SECONDS=10
VANCOUVER_OPENDATA_ENFORCE_HOST_ALLOWLIST=true

# --- Vite dev proxy (optional; defaults in frontend/vite.config.ts) ---
# API_PROXY_TARGET=http://127.0.0.1:1111
# AI_PROXY_TARGET=http://127.0.0.1:8001
