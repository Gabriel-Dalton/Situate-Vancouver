# Copy variables you need into the repository root `.env` (Django loads REPO_ROOT/.env).

# Public hostname(s) when using Cloudflare Tunnel (comma-separated, no spaces).
# In Cloudflare DNS: use a CNAME to your tunnel (e.g. xxx.cfargotunnel.com), proxied —
# do NOT create an A record pointing at Cloudflare edge IPs (that causes Error 1000).
# Use a leading dot to allow apex + all subdomains: ".example.com"
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,.example.com
# DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com
# DJANGO_USE_X_FORWARDED_HEADERS=true
# If you still see DisallowedHost / HTTP 400 behind a tunnel while debugging:
# DJANGO_ALLOW_ALL_HOSTS=true

# Skip AI in GET /api/health when FastAPI is not running (default true).
# HEALTH_CHECK_AI=false

# --- Vancouver Open Data (Opendatasoft Explore API v2.1) ---
# Key from https://opendata.vancouver.ca/account/
VANCOUVER_OPENDATA_BASE_URL=https://opendata.vancouver.ca
VANCOUVER_OPENDATA_API_KEY=replace-with-your-api-key
VANCOUVER_OPENDATA_TIMEOUT_SECONDS=10
VANCOUVER_OPENDATA_ENFORCE_HOST_ALLOWLIST=true
