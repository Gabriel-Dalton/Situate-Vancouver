# Copy to `.env` at the repository root. Django, `make run` / dev-run.sh, Vite, and child processes read this file.

# --- Local dev servers (`make run`: uvicorn + Vite + Django; all values below are optional except where noted) ---
DJANGO_DEV_HOST=127.0.0.1
DJANGO_DEV_PORT=1111
AI_DEV_HOST=127.0.0.1
AI_DEV_PORT=8001
FRONTEND_DEV_HOST=127.0.0.1
FRONTEND_DEV_PORT=5173

# Django -> FastAPI (GET /api/health, POST /api/query). For `make run`, scripts/dev-run.sh sets
# AI_SERVICE_URL from AI_DEV_HOST/AI_DEV_PORT so it always matches uvicorn. If you start Django
# without that script, set this to the same host:port FastAPI listens on (same machine → 127.0.0.1).
AI_SERVICE_URL=http://127.0.0.1:8001
# Django POST /api/query/ -> FastAPI /incidents/query (seconds)
# AI_QUERY_TIMEOUT_SECONDS=120

# Vite dev proxy targets (loadEnv uses repo root)
API_PROXY_TARGET=http://127.0.0.1:1111
AI_PROXY_TARGET=http://127.0.0.1:8001
# Optional: extra Host values allowed by the Vite dev server (comma-separated). Defaults already include www.ageforty.com, ageforty.com, api.ageforty.com.
# VITE_ALLOWED_HOSTS=my-tunnel.example.com
# Optional: Host header for requests proxied to Django (e.g. 127.0.0.1:1111) when API_PROXY_TARGET uses a public hostname that resolves locally.
# API_PROXY_FORWARD_HOST=127.0.0.1:1111

# FastAPI CORS (comma-separated, no spaces around commas). If you change FRONTEND_DEV_PORT, add matching origins here.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:1111,http://127.0.0.1:1111

# Skip AI in GET /api/health when FastAPI is not running (default: check AI)
# HEALTH_CHECK_AI=false

# --- Django ---
# DJANGO_SECRET_KEY=change-me
# DJANGO_DEBUG=true
# Comma-separated hostnames Django accepts in the HTTP Host header (no spaces).
# Production: include your public domain(s) or GET /api/health/ returns HTTP 400 DisallowedHost.
# Example: DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,www.ageforty.com,ageforty.com,api.ageforty.com
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
# DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Behind Cloudflare / TLS terminator: trust X-Forwarded-Proto and X-Forwarded-Host.
# DJANGO_CSRF_TRUSTED_ORIGINS=https://www.ageforty.com,https://ageforty.com,https://api.ageforty.com
# DJANGO_USE_X_FORWARDED_HEADERS=true
# DJANGO_ALLOW_ALL_HOSTS=true

# --- AI service (repo-root `.env`: loaded by `make run`, Django, and ai-service via python-dotenv) ---
# Required for POST /incidents/query and /incidents/report (and Django POST /api/query/).
OPENAI_API_KEY=
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_USERNAME=default
# REDIS_PASSWORD=

# --- Vancouver Open Data (Django + AI retriever) ---
VANCOUVER_OPENDATA_BASE_URL=https://opendata.vancouver.ca
VANCOUVER_OPENDATA_API_KEY=replace-with-your-api-key
VANCOUVER_OPENDATA_TIMEOUT_SECONDS=10
VANCOUVER_OPENDATA_ENFORCE_HOST_ALLOWLIST=true

# Copy checks.vancouver_opendata from another deployment's GET /api/health JSON (local dev).
# Do not set to this server's own /api/health URL (avoid self-fetch recursion).
# HEALTH_VANCOUVER_OPENDATA_STATUS_URL=
